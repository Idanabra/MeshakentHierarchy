{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/foundation/**",
              "components/navigation/**",
              "ui_kits/sample-management/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:72|72-SemiboldDuplex|72Mono|SAP-icons))/i]",
        "message": "Font not provided by the design system. Available: 72, 72-SemiboldDuplex, 72Mono, SAP-icons."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|icon|src|size|colorScheme|shape|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, icon, src, size, colorScheme, shape, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:XS|S|M|L|XL)$/]",
        "message": "<Avatar> size must be one of 'XS' | 'S' | 'M' | 'L' | 'XL'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:circle|square)$/]",
        "message": "<Avatar> shape must be one of 'circle' | 'square'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|colorScheme|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, colorScheme, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='colorScheme'] > Literal[value!=/^(?:Neutral|Information|Success|Warning|Error)$/]",
        "message": "<Badge> colorScheme must be one of 'Neutral' | 'Information' | 'Success' | 'Warning' | 'Error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|design|icon|iconEnd|size|disabled|onClick|type|title|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, design, icon, iconEnd, size, disabled, onClick, type, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='design'] > Literal[value!=/^(?:default|emphasized|transparent|positive|negative|attention)$/]",
        "message": "<Button> design must be one of 'default' | 'emphasized' | 'transparent' | 'positive' | 'negative' | 'attention'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:cozy|compact)$/]",
        "message": "<Button> size must be one of 'cozy' | 'compact'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|headerIcon|headerAction|children|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: title, subtitle, headerIcon, headerAction, children, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dialog'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|footer|onClose|width|style|key|ref|className|style|children)$/]",
        "message": "<Dialog> doesn't accept that prop. Declared props: open, title, children, footer, onClose, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|title|style|className|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, title, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|onChange|placeholder|label|type|valueState|valueStateText|icon|disabled|readOnly|required|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, onChange, placeholder, label, type, valueState, valueStateText, icon, disabled, readOnly, required, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='valueState'] > Literal[value!=/^(?:None|Error|Warning|Success|Information)$/]",
        "message": "<Input> valueState must be one of 'None' | 'Error' | 'Warning' | 'Success' | 'Information'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:design|children|onClose|showIcon|style|key|ref|className|style|children)$/]",
        "message": "<MessageStrip> doesn't accept that prop. Declared props: design, children, onClose, showIcon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MessageStrip'] > JSXAttribute[name.name='design'] > Literal[value!=/^(?:Information|Success|Warning|Error)$/]",
        "message": "<MessageStrip> design must be one of 'Information' | 'Success' | 'Warning' | 'Error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ObjectStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|icon|showIcon|children|style|key|ref|className|style|children)$/]",
        "message": "<ObjectStatus> doesn't accept that prop. Declared props: state, icon, showIcon, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ObjectStatus'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:None|Positive|Negative|Critical|Information|Neutral)$/]",
        "message": "<ObjectStatus> state must be one of 'None' | 'Positive' | 'Negative' | 'Critical' | 'Information' | 'Neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ShellBarAction'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|onClick|key|ref|className|style|children)$/]",
        "message": "<ShellBarAction> doesn't accept that prop. Declared props: icon, title, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|disabled|label|id|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, disabled, label, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Token'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onRemove|selected|style|key|ref|className|style|children)$/]",
        "message": "<Token> doesn't accept that prop. Declared props: children, onRemove, selected, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
